<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaNovel.ViewModels"
             x:Class="AvaloniaNovel.Views.CreateView"
             x:DataType="vm:CreateViewModel">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource SukiCardBackgroundBrush}"
                Padding="16,12" Margin="0">
            <Grid RowDefinitions="Auto,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="8,0,8,12">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentNovel.Title, FallbackValue='未选择小说'}"
                                   FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SelectedChapter.Order, StringFormat={}第 {0} 章}"
                                   FontSize="16" Foreground="{DynamicResource SukiTextColorBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   IsVisible="{Binding SelectedChapter, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="生成大纲" Command="{Binding GenerateOutlineCommand}"
                                IsEnabled="{Binding !IsWriting}" Classes="Flat" />
                        <Button Content="开始写作" Command="{Binding StartWritingCommand}"
                                IsEnabled="{Binding !IsWriting}" />
                        <Button Content="停止" Command="{Binding StopWritingCommand}"
                                IsEnabled="{Binding IsWriting}" Classes="Flat" />
                        <Button Content="导出" Command="{Binding ExportCommand}" Classes="Flat" />
                    </StackPanel>
                </Grid>
                <ProgressBar Grid.Row="1" IsIndeterminate="True" IsVisible="{Binding IsWriting}"
                             Height="3" Margin="8,0" />
            </Grid>
        </Border>

        <Grid ColumnDefinitions="320,*">
            <Border Grid.Column="0" Margin="12" CornerRadius="8"
                    Background="{DynamicResource SukiCardBackgroundBrush}">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top" Text="章节列表" FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,12" />
                    <ListBox ItemsSource="{Binding Chapters}"
                             SelectedItem="{Binding SelectedChapter}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SukiBackgroundBrush}"
                                        CornerRadius="6" Margin="0,0,0,6" Padding="12,10">
                                    <Grid RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="1" Text="{Binding Summary}"
                                                   Foreground="{DynamicResource SukiTextColorBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                                   MaxHeight="36" TextTrimming="CharacterEllipsis"
                                                   FontSize="12" />
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                            <Border Background="{DynamicResource SukiAccentColorBrush}"
                                                    CornerRadius="3" Padding="6,2">
                                                <TextBlock Text="{Binding Status}" FontSize="10"
                                                           Foreground="White" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Margin="0,12,12,12" CornerRadius="8"
                    Background="{DynamicResource SukiCardBackgroundBrush}">
                <ScrollViewer Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding SelectedChapter.Title, FallbackValue='选择章节开始创作'}"
                                       FontSize="22" FontWeight="Bold" TextWrapping="Wrap" />
                            <Border Height="1" Background="{DynamicResource SukiTextColorBrush}"
                                    Opacity="0.2" Margin="0,4" />
                        </StackPanel>
                        <TextBlock
                            Text="{Binding SelectedChapter.Content, FallbackValue='暂无内容\n\n从左侧选择一个章节，或生成新的大纲开始创作。'}"
                            TextWrapping="Wrap" LineHeight="28" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border IsVisible="{Binding StatusMessage, Converter={x:Static vm:StringNullOrEmptyConverter.Instance}}"
                DockPanel.Dock="Bottom" Background="{DynamicResource SukiCardBackgroundBrush}"
                Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource SukiAccentColorBrush}"
                       HorizontalAlignment="Center" />
        </Border>
    </DockPanel>
</UserControl>

