<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaNovel.ViewModels"
             xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:fl="using:FluentIcons.Common"
             x:Class="AvaloniaNovel.Views.CreateView"
             x:DataType="vm:CreateViewModel">

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="20,14" Margin="0"
                Background="{StaticResource SurfaceColor}">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="8" Opacity="0.06" OffsetY="2" />
            </Border.Effect>
            <Grid RowDefinitions="Auto,Auto,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentNovel.Title, FallbackValue='未选择小说'}"
                                   FontSize="26" FontWeight="Bold" VerticalAlignment="Center" />
                        <Border Background="{StaticResource PrimaryColor}" Opacity="0.1" CornerRadius="999" Padding="10,5" Margin="4,0,0,0">
                            <TextBlock Text="{Binding SelectedChapter.Order, StringFormat={}第 {0} 章}"
                                       FontSize="14" Foreground="{StaticResource PrimaryColor}"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding SelectedChapter, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="生成大纲" Command="{Binding GenerateOutlineCommand}"
                                IsEnabled="{Binding !IsWriting}" />
                        <Button Content="开始写作" Command="{Binding StartWritingCommand}"
                                IsEnabled="{Binding !IsWriting}" />
                        <Button Content="停止" Command="{Binding StopWritingCommand}"
                                IsEnabled="{Binding IsWriting}"
                                Classes="Danger" />
                        <Button Content="重写本章" Command="{Binding RewriteChapterCommand}"
                                IsEnabled="{Binding !IsWriting}"
                                Classes="Secondary" />
                        <Button Content="保存快照" Command="{Binding SaveSnapshotCommand}"
                                Classes="Secondary" />
                        <Button Content="导出" Command="{Binding ExportCommand}"
                                Classes="Secondary" />
                        <Button Content="模板" Command="{Binding ToggleTemplatePanelCommand}"
                                Classes="Secondary" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" CornerRadius="8" Margin="0,0,0,12"
                        Background="{StaticResource SurfaceAltColor}" Height="6">
                    <ProgressBar IsIndeterminate="True"
                                 Height="6" CornerRadius="4"
                                 IsVisible="{Binding IsWriting}" />
                </Border>

                <Border Grid.Row="2" CornerRadius="12" Padding="16"
                        Background="{StaticResource SurfaceAltColor}">
                    <Grid RowDefinitions="Auto,Auto">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding InstructionText}"
                                     PlaceholderText="输入剧情调整指令，如：让主角失忆、加入穿越元素..."
                                     VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="12,0,0,0">
                                <Button Content="发送指令" Command="{Binding SendInstructionCommand}"
                                        IsEnabled="{Binding !IsWriting}" />
                                <Button Content="历史版本" Command="{Binding ToggleVersionPanelCommand}"
                                        Classes="Secondary" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" IsVisible="{Binding ShowVersionPanel}"
                                CornerRadius="10" Margin="0,12,0,0" Padding="16"
                                Background="{StaticResource SurfaceColor}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                                    <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Clock}" IconVariant="Regular" FontSize="16" Foreground="{StaticResource PrimaryColor}" />
                                    <TextBlock Text="版本历史" FontSize="15" FontWeight="SemiBold" />
                                </StackPanel>
                                <ScrollViewer MaxHeight="180">
                                    <ItemsControl ItemsSource="{Binding Versions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="8" Padding="12" Margin="0,0,0,6"
                                                        Background="{StaticResource SurfaceAltColor}">
                                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:MM/dd HH:mm}}"
                                                                       FontSize="12" Foreground="{StaticResource TextTertiary}" />
                                                            <TextBlock Text="{Binding Trigger}" FontSize="13" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding WordCount, StringFormat={}{0} 字}"
                                                                   FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="12,0" />
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                                            <Button Content="查看" Command="{Binding $parent[ItemsControl].((vm:CreateViewModel)DataContext).ViewVersionCommand}"
                                                                    CommandParameter="{Binding}" FontSize="11" Padding="8,4" Classes="Secondary" />
                                                            <Button Content="回滚" Command="{Binding $parent[ItemsControl].((vm:CreateViewModel)DataContext).RollbackVersionCommand}"
                                                                    CommandParameter="{Binding}" FontSize="11" Padding="8,4" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="3" IsVisible="{Binding ShowTemplatePanel}"
                        CornerRadius="12" Padding="16" Margin="0,12,0,0"
                        Background="{StaticResource SurfaceAltColor}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Document}" IconVariant="Regular" FontSize="16" Foreground="{StaticResource PrimaryColor}" />
                            <TextBlock Text="提示词模板选择" FontSize="15" FontWeight="SemiBold" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="系统人设" FontSize="13" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding SystemTemplates}"
                                          SelectedItem="{Binding SelectedSystemTemplate}"
                                          HorizontalAlignment="Stretch"
                                          MinWidth="140">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="大纲生成" FontSize="13" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding OutlineTemplates}"
                                          SelectedItem="{Binding SelectedOutlineTemplate}"
                                          HorizontalAlignment="Stretch"
                                          MinWidth="140">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="章节写作" FontSize="13" Foreground="{StaticResource TextSecondary}" />
                                <ComboBox ItemsSource="{Binding ChapterTemplates}"
                                          SelectedItem="{Binding SelectedChapterTemplate}"
                                          HorizontalAlignment="Stretch"
                                          MinWidth="140">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="10" Margin="0,12,0,0"
                            IsVisible="{Binding IsStreaming}">
                    <Border Width="24" Height="24" CornerRadius="12" Background="{StaticResource PrimaryColor}" Opacity="0.1">
                        <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Flash}" IconVariant="Regular" FontSize="14" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="正在生成..." FontSize="14"
                               Foreground="{StaticResource PrimaryColor}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentWordCount, StringFormat={}{0} 字}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryColor}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Border IsVisible="{Binding StatusMessage, Converter={x:Static vm:StringNullOrEmptyConverter.Instance}}"
                DockPanel.Dock="Bottom" Padding="16,10"
                Background="{StaticResource SurfaceColor}">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="8" Opacity="0.06" OffsetY="-2" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Info}" IconVariant="Regular" FontSize="16" Foreground="{StaticResource PrimaryColor}" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource PrimaryColor}"
                           FontSize="14" />
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="340,*">
            <Border Grid.Column="0" Margin="16" CornerRadius="16"
                    Background="{StaticResource SurfaceColor}"
                    Classes="Card">
                <DockPanel Margin="16">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,14">
                        <ic:SymbolIcon Symbol="{x:Static fl:Symbol.List}" IconVariant="Regular" FontSize="18" Foreground="{StaticResource PrimaryColor}" />
                        <TextBlock Text="章节列表" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                    <ScrollViewer MaxHeight="400">
                        <ListBox ItemsSource="{Binding Chapters}"
                                 SelectedItem="{Binding SelectedChapter}"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Margin="0,0,0,8" Padding="14,12"
                                            Background="{StaticResource SurfaceAltColor}"
                                            Cursor="Hand">
                                        <Grid RowDefinitions="Auto,Auto,Auto">
                                            <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="SemiBold"
                                                       TextWrapping="Wrap" FontSize="14" />
                                            <TextBlock Grid.Row="1" Text="{Binding Summary}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       TextWrapping="Wrap" Margin="0,6,0,0"
                                                       MaxHeight="40" TextTrimming="CharacterEllipsis"
                                                       FontSize="12" />
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                                <Border CornerRadius="6" Padding="8,4"
                                                        Background="{Binding Status, Converter={x:Static vm:ChapterStatusColorConverter.Instance}}">
                                                    <TextBlock Text="{Binding Status}" FontSize="11"
                                                               Foreground="White" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Margin="0,16,16,16" CornerRadius="16"
                    Background="{StaticResource SurfaceColor}"
                    Classes="Card">
                <ScrollViewer Name="ContentScrollViewer" Padding="24">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding SelectedChapter.Title, FallbackValue='选择章节开始创作'}"
                                       FontSize="26" FontWeight="Bold" TextWrapping="Wrap" />
                            <Border Height="2"
                                    Background="{StaticResource BorderColor}"
                                    Opacity="0.3" />
                        </StackPanel>

                        <md:MarkdownRenderer Name="ContentRenderer" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>