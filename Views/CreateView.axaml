<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaNovel.ViewModels"
             xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
             x:Class="AvaloniaNovel.Views.CreateView"
             x:DataType="vm:CreateViewModel">

    <DockPanel>
        <!-- ── 顶部工具栏 ───────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SukiCardBackgroundBrush}"
                Padding="16,12" Margin="0">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                <!-- 标题 + 按钮行 -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="8,0,8,12">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentNovel.Title, FallbackValue='未选择小说'}"
                                   FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SelectedChapter.Order, StringFormat={}第 {0} 章}"
                                   FontSize="16" Foreground="{DynamicResource SukiTextColorBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   IsVisible="{Binding SelectedChapter, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="生成大纲" Command="{Binding GenerateOutlineCommand}"
                                IsEnabled="{Binding !IsWriting}" Classes="Flat" />
                        <Button Content="开始写作" Command="{Binding StartWritingCommand}"
                                IsEnabled="{Binding !IsWriting}" />
                        <Button Content="停止" Command="{Binding StopWritingCommand}"
                                IsEnabled="{Binding IsWriting}" Classes="Flat" />
                        <Button Content="导出" Command="{Binding ExportCommand}" Classes="Flat" />
                        <Button Content="📝模板" Command="{Binding ToggleTemplatePanelCommand}"
                                Classes="Flat" />
                    </StackPanel>
                </Grid>

                <!-- 进度条 -->
                <Grid Grid.Row="1" Margin="8,0,8,4">
                    <ProgressBar IsIndeterminate="True"
                                 Height="3"
                                 IsVisible="{Binding IsWriting}" />
                </Grid>

                <!-- 模板选择面板（可折叠） -->
                <Border Grid.Row="2" IsVisible="{Binding ShowTemplatePanel}"
                        Background="{DynamicResource SukiBackgroundBrush}"
                        CornerRadius="10" Padding="14" Margin="8,0,8,8">
                    <StackPanel Spacing="10">
                        <TextBlock Text="提示词模板选择" FontSize="13" FontWeight="SemiBold" Opacity="0.8" />
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <!-- 系统人设 -->
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="系统人设" FontSize="12" Opacity="0.7" />
                                <ComboBox ItemsSource="{Binding SystemTemplates}"
                                          SelectedItem="{Binding SelectedSystemTemplate}"
                                          HorizontalAlignment="Stretch"
                                          MinWidth="120">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <!-- 大纲模板 -->
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="大纲生成" FontSize="12" Opacity="0.7" />
                                <ComboBox ItemsSource="{Binding OutlineTemplates}"
                                          SelectedItem="{Binding SelectedOutlineTemplate}"
                                          HorizontalAlignment="Stretch"
                                          MinWidth="120">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <!-- 章节模板 -->
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="章节写作" FontSize="12" Opacity="0.7" />
                                <ComboBox ItemsSource="{Binding ChapterTemplates}"
                                          SelectedItem="{Binding SelectedChapterTemplate}"
                                          HorizontalAlignment="Stretch"
                                          MinWidth="120">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 流式写作字数提示 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="8,0,8,0"
                            IsVisible="{Binding IsStreaming}">
                    <TextBlock Text="✍️ 正在生成..." FontSize="12"
                               Foreground="{DynamicResource SukiAccentColorBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentWordCount, StringFormat={}{0} 字}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource SukiAccentColorBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 底部状态栏 ───────────────────────────────────────────── -->
        <Border IsVisible="{Binding StatusMessage, Converter={x:Static vm:StringNullOrEmptyConverter.Instance}}"
                DockPanel.Dock="Bottom" Background="{DynamicResource SukiCardBackgroundBrush}"
                Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource SukiAccentColorBrush}"
                       HorizontalAlignment="Center" />
        </Border>

        <!-- ── 主体：章节列表 + 内容区 ─────────────────────────────── -->
        <Grid ColumnDefinitions="320,*">
            <!-- 章节列表 -->
            <Border Grid.Column="0" Margin="12" CornerRadius="8"
                    Background="{DynamicResource SukiCardBackgroundBrush}">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top" Text="章节列表" FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,12" />
                    <ListBox ItemsSource="{Binding Chapters}"
                             SelectedItem="{Binding SelectedChapter}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SukiBackgroundBrush}"
                                        CornerRadius="6" Margin="0,0,0,6" Padding="12,10">
                                    <Grid RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="1" Text="{Binding Summary}"
                                                   Foreground="{DynamicResource SukiTextColorBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                                   MaxHeight="36" TextTrimming="CharacterEllipsis"
                                                   FontSize="12" />
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                            <Border Background="{DynamicResource SukiAccentColorBrush}"
                                                    CornerRadius="3" Padding="6,2">
                                                <TextBlock Text="{Binding Status}" FontSize="10"
                                                           Foreground="White" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 内容区：Markdown 实时渲染 -->
            <Border Grid.Column="1" Margin="0,12,12,12" CornerRadius="8"
                    Background="{DynamicResource SukiCardBackgroundBrush}">
                <ScrollViewer Name="ContentScrollViewer" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding SelectedChapter.Title, FallbackValue='选择章节开始创作'}"
                                       FontSize="22" FontWeight="Bold" TextWrapping="Wrap" />
                            <Border Height="1" Background="{DynamicResource SukiTextColorBrush}"
                                    Opacity="0.2" Margin="0,4" />
                        </StackPanel>

                        <!-- Markdown 渲染器：通过 code-behind 绑定 MarkdownBuilder -->
                        <md:MarkdownRenderer Name="ContentRenderer" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
