<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaNovel.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:fl="using:FluentIcons.Common"
             x:Class="AvaloniaNovel.Views.BookshelfView"
             x:DataType="vm:BookshelfViewModel">

    <Grid>
        <ScrollViewer Padding="32,28"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid RowDefinitions="Auto,Auto,*"
                  RowSpacing="24">
                <Border Grid.Row="0"
                        CornerRadius="24"
                        Padding="24"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource SurfaceColor}"
                        Classes="Card">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="24">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.List}" IconVariant="Regular" FontSize="18"
                                               Foreground="{StaticResource AccentColor}" />
                                <TextBlock Text="当前视图"
                                           Foreground="{StaticResource TextSecondary}" />
                            </StackPanel>
                            <TextBlock Text="作品列表"
                                       FontSize="32"
                                       FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Button Content="新建小说" Command="{Binding OpenNewNovelDialogCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        CornerRadius="16"
                        Padding="20"
                        Background="{StaticResource SurfaceColor}"
                        Classes="Card">
                    <Grid ColumnDefinitions="*,*,*,*">
                        <StackPanel Grid.Column="0" Spacing="6" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Book}" IconVariant="Regular" FontSize="20"
                                               Foreground="{StaticResource PrimaryColor}" />
                                <TextBlock Text="小说总数" Foreground="{StaticResource TextSecondary}" FontSize="14" />
                            </StackPanel>
                            <TextBlock Text="{Binding Novels.Count}" FontSize="28" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Checkmark}" IconVariant="Regular"
                                               FontSize="20" Foreground="{StaticResource AccentColor}" />
                                <TextBlock Text="有封面" Foreground="{StaticResource TextSecondary}" FontSize="14" />
                            </StackPanel>
                            <TextBlock Text="{Binding NovelsWithCover}" FontSize="28" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Edit}" IconVariant="Regular" FontSize="20"
                                               Foreground="{StaticResource WarningColor}" />
                                <TextBlock Text="创作中" Foreground="{StaticResource TextSecondary}" FontSize="14" />
                            </StackPanel>
                            <TextBlock Text="{Binding CoverStatusText}" FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="120" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="6" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.List}" IconVariant="Regular" FontSize="20"
                                               Foreground="{StaticResource SecondaryColor}" />
                                <TextBlock Text="总章节数" Foreground="{StaticResource TextSecondary}" FontSize="14" />
                            </StackPanel>
                            <TextBlock Text="-" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        CornerRadius="24"
                        Padding="24"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource SurfaceColor}"
                        Classes="Card">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,16">
                            <TextBlock Text="作品列表"
                                       FontSize="24"
                                       FontWeight="Bold" />
                            <TextBlock Text="点击卡片进入创作，右侧按钮可快速操作。"
                                       Foreground="{StaticResource TextSecondary}" />
                        </StackPanel>

                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding Novels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="20"
                                                Width="260"
                                                Margin="0,0,20,20"
                                                Background="{StaticResource SurfaceColor}"
                                                BorderBrush="{StaticResource BorderColor}"
                                                BorderThickness="1"
                                                Cursor="Hand">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#42B883" BlurRadius="8" Opacity="0.06"
                                                                  OffsetY="2" />
                                            </Border.Effect>
                                            <StackPanel>
                                                <Border CornerRadius="20,20,0,0"
                                                        Height="150"
                                                        ClipToBounds="True">
                                                    <Panel>
                                                        <Border Background="{StaticResource PrimaryColor}"
                                                                Opacity="0.08">
                                                            <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Book}"
                                                                           IconVariant="Regular" FontSize="56"
                                                                           Foreground="{StaticResource PrimaryColor}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" />
                                                        </Border>
                                                        <Image
                                                            Source="{Binding CoverImagePath, Converter={x:Static vm:FilePathToBitmapConverter.Instance}}"
                                                            Stretch="UniformToFill"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                                    </Panel>
                                                </Border>
                                                <StackPanel Margin="16,14">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               FontSize="15"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding WorldSetting}"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="36"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,4,0,0"
                                                               FontSize="12" />
                                                    <Border Margin="0,10,0,0"
                                                            CornerRadius="8"
                                                            Padding="8,4"
                                                            Background="{StaticResource SurfaceAltColor}"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Genre}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   MaxWidth="200"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                                                        <Button Content="创作"
                                                                Command="{Binding $parent[ItemsControl].((vm:BookshelfViewModel)DataContext).OpenNovelCommand}"
                                                                CommandParameter="{Binding}"
                                                                Padding="14,8"
                                                                FontSize="12" />
                                                        <Button Content="删除"
                                                                Command="{Binding $parent[ItemsControl].((vm:BookshelfViewModel)DataContext).ConfirmDeleteCommand}"
                                                                CommandParameter="{Binding}"
                                                                Padding="14,8"
                                                                FontSize="12"
                                                                Classes="Danger" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel IsVisible="{Binding !Novels.Count}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="16"
                                    Margin="0,60">
                            <Border Width="100" Height="100" CornerRadius="50"
                                    Background="{StaticResource SurfaceAltColor}">
                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Book}" IconVariant="Regular" FontSize="48"
                                               Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="还没有小说"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="点击上方按钮创建第一本小说"
                                           Foreground="{StaticResource TextSecondary}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                            <Button Content="新建小说"
                                    Command="{Binding OpenNewNovelDialogCommand}"
                                    HorizontalAlignment="Center"
                                    Margin="0,8,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>