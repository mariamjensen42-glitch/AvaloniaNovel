<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaNovel.ViewModels"
        xmlns:views="using:AvaloniaNovel.Views"
        xmlns:ic="using:FluentIcons.Avalonia"
        xmlns:fl="using:FluentIcons.Common"
        x:Class="AvaloniaNovel.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AINovelFlow - AI 网文创作工具"
        Width="1200"
        Height="750"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="260,*">
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceColor}"
                Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" Opacity="0.08" OffsetX="4" />
            </Border.Effect>
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Grid.Row="0" Spacing="16" Margin="20,24,20,16">
                    <Border Background="{StaticResource PrimaryColor}"
                            CornerRadius="16" Padding="20"
                            Effect="{x:Null}">
                        <StackPanel Spacing="14">
                            <Border Width="48" Height="48" CornerRadius="14"
                                    Background="White" Opacity="0.2">
                                <TextBlock Text="AI" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="20" FontWeight="Bold" Foreground="White" />
                            </Border>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding AppTitle}" FontSize="22" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="{Binding AppTagline}" Opacity="0.85" FontSize="12" Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ListBox Grid.Row="1" x:Name="NavListBox" Margin="12,0"
                         SelectionMode="Single" SelectedIndex="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="CornerRadius" Value="12" />
                            <Setter Property="Padding" Value="16,12" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="Transitions">
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="200" />
                                    <BrushTransition Property="Foreground" Duration="200" />
                                </Transitions>
                            </Setter>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Background" Value="{StaticResource PrimaryColor}" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="Effect">
                                <DropShadowEffect Color="#42B883" BlurRadius="10" Opacity="0.2" OffsetY="2" />
                            </Setter>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover:not(:selected)">
                            <Setter Property="Background" Value="{StaticResource SurfaceHoverColor}" />
                        </Style>
                    </ListBox.Styles>
                    <ListBoxItem x:Name="BookshelfNavItem">
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Width="28" Height="28" CornerRadius="8" Background="Transparent">
                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Library}" IconVariant="Regular"
                                               FontSize="18" />
                            </Border>
                            <TextBlock Text="书架" FontSize="15" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="CreateNavItem">
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Width="28" Height="28" CornerRadius="8" Background="Transparent">
                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Edit}" IconVariant="Regular" FontSize="18" />
                            </Border>
                            <TextBlock Text="创作" FontSize="15" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="SettingsNavItem">
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Width="28" Height="28" CornerRadius="8" Background="Transparent">
                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Settings}" IconVariant="Regular"
                                               FontSize="18" />
                            </Border>
                            <TextBlock Text="设置" FontSize="15" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="TemplateNavItem">
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Width="28" Height="28" CornerRadius="8" Background="Transparent">
                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Document}" IconVariant="Regular"
                                               FontSize="18" />
                            </Border>
                            <TextBlock Text="模板" FontSize="15" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <Border Grid.Row="2" Margin="16,12" Background="{StaticResource SurfaceAltColor}"
                        CornerRadius="999" Padding="14,8" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ActiveSectionTitle}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource SurfaceAltColor}">
            <Grid x:Name="ContentArea">
                <views:BookshelfView x:Name="BookshelfPage" DataContext="{Binding BookshelfViewModel}" />
                <views:CreateView x:Name="CreatePage" DataContext="{Binding CreateViewModel}" IsVisible="False" />
                <views:SettingsView x:Name="SettingsPage" DataContext="{Binding SettingsViewModel}" IsVisible="False" />
                <views:PromptTemplateView x:Name="TemplatePage" DataContext="{Binding PromptTemplateViewModel}"
                                          IsVisible="False" />
            </Grid>
        </Border>
    </Grid>
</Window>