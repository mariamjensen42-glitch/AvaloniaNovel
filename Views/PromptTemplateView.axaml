<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             xmlns:theme="clr-namespace:SukiUI.Theme;assembly=SukiUI"
             xmlns:vm="using:AvaloniaNovel.ViewModels"
             xmlns:models="using:AvaloniaNovel.Models"
             x:Class="AvaloniaNovel.Views.PromptTemplateView"
             x:DataType="vm:PromptTemplateViewModel">

    <Border Background="{DynamicResource SukiCardBackgroundBrush}"
            CornerRadius="22"
            Padding="22">
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- 标题区 -->
            <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,16">
                <TextBlock Text="提示词模板"
                           FontSize="22"
                           FontWeight="Bold" />
                <TextBlock Text="自定义系统人设、大纲生成和章节写作的提示词。支持 {{genre}}、{{worldSetting}}、{{chapterTitle}}、{{chapterSummary}}、{{previousSummary}} 等占位符变量。"
                           TextWrapping="Wrap"
                           Opacity="0.72" />
            </StackPanel>

            <!-- 类型筛选 + 操作栏 -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="全部"
                            Command="{Binding FilterByTypeCommand}"
                            CommandParameter="{x:Null}"
                            Classes="Flat" />
                    <Button Content="系统人设"
                            Command="{Binding FilterByTypeCommand}"
                            CommandParameter="{x:Static models:PromptTemplateType.System}"
                            Classes="Flat" />
                    <Button Content="大纲生成"
                            Command="{Binding FilterByTypeCommand}"
                            CommandParameter="{x:Static models:PromptTemplateType.Outline}"
                            Classes="Flat" />
                    <Button Content="章节写作"
                            Command="{Binding FilterByTypeCommand}"
                            CommandParameter="{x:Static models:PromptTemplateType.Chapter}"
                            Classes="Flat" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="新建模板"
                            Command="{Binding NewTemplateCommand}"
                            Classes="Accent" />
                </StackPanel>
            </Grid>

            <!-- 主体：模板列表 + 编辑区 -->
            <Grid Grid.Row="2" ColumnDefinitions="280,*" ColumnSpacing="16">

                <!-- 左：模板列表 -->
                <Border Background="{DynamicResource SukiBackgroundBrush}"
                        CornerRadius="14"
                        Padding="8">
                    <ListBox ItemsSource="{Binding Templates}"
                             SelectedItem="{Binding SelectedTemplate}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:PromptTemplate">
                                <StackPanel Spacing="4" Margin="4,6">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Background="{DynamicResource SukiAccentColorBrush}"
                                                CornerRadius="3" Padding="6,2">
                                            <TextBlock FontSize="10" Foreground="White">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}">
                                                        <Binding Path="Type" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                        <Border IsVisible="{Binding IsBuiltIn}"
                                                Background="#40767776"
                                                CornerRadius="3" Padding="6,2">
                                            <TextBlock Text="内置" FontSize="10" Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- 右：详情 / 编辑 -->
                <Grid>
                    <!-- 未选中时 -->
                    <StackPanel IsVisible="{Binding SelectedTemplate, Converter={x:Static ObjectConverters.IsNull}}"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Spacing="8" Opacity="0.5">
                        <TextBlock Text="选择左侧模板查看详情，或点击「新建模板」创建"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- 选中 - 查看模式 -->
                    <ScrollViewer IsVisible="{Binding !IsEditing}">
                        <StackPanel Spacing="16">
                            <!-- 模板名称 + 类型 -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding SelectedTemplate.Name}"
                                           FontSize="20" FontWeight="Bold" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{DynamicResource SukiAccentColorBrush}"
                                            CornerRadius="3" Padding="8,3">
                                        <TextBlock Text="{Binding SelectedTemplate.Type}"
                                                   FontSize="11" Foreground="White" />
                                    </Border>
                                    <Border IsVisible="{Binding SelectedTemplate.IsBuiltIn}"
                                            Background="#40767776"
                                            CornerRadius="3" Padding="8,3">
                                        <TextBlock Text="内置模板" FontSize="11" Foreground="White" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- 模板内容（只读） -->
                            <Border Background="{DynamicResource SukiCardBackgroundBrush}"
                                    CornerRadius="10" Padding="14" MinHeight="200">
                                <TextBlock Text="{Binding SelectedTemplate.Content}"
                                           TextWrapping="Wrap"
                                           FontFamily="Consolas,Menlo,monospace"
                                           FontSize="13"
                                           LineHeight="20" />
                            </Border>

                            <!-- 操作按钮 -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="编辑" Command="{Binding EditTemplateCommand}" />
                                <Button Content="复制" Command="{Binding DuplicateTemplateCommand}"
                                        Classes="Flat" />
                                <Button Content="删除" Command="{Binding DeleteTemplateCommand}"
                                        Classes="Flat"
                                        IsVisible="{Binding !SelectedTemplate.IsBuiltIn}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 编辑模式 -->
                    <StackPanel IsVisible="{Binding IsEditing}" Spacing="16">
                        <TextBlock Text="编辑模板" FontSize="18" FontWeight="SemiBold" />

                        <StackPanel Spacing="8">
                            <TextBlock Text="模板名称" FontWeight="SemiBold" />
                            <TextBox Text="{Binding EditName}"
                                     Watermark="输入模板名称" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="模板类型" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding TemplateTypes}"
                                      SelectedItem="{Binding EditType}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="模板内容" FontWeight="SemiBold" />
                            <TextBox Text="{Binding EditContent}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas,Menlo,monospace"
                                     FontSize="13"
                                     MinHeight="260"
                                     Watermark="输入提示词模板内容...&#x0a;支持占位符: {{genre}}, {{worldSetting}}, {{chapterTitle}}, {{chapterSummary}}, {{previousSummary}}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="保存" Command="{Binding SaveTemplateCommand}"
                                    Classes="Accent"
                                    IsEnabled="{Binding !IsSaving}" />
                            <Button Content="取消" Command="{Binding CancelEditCommand}"
                                    Classes="Flat" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
