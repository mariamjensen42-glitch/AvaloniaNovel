<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaNovel.ViewModels"
             xmlns:models="using:AvaloniaNovel.Models"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:fl="using:FluentIcons.Common"
             x:Class="AvaloniaNovel.Views.PromptTemplateView"
             x:DataType="vm:PromptTemplateViewModel">

    <Grid ColumnDefinitions="340,*">
        <Border Grid.Column="0" Margin="16" CornerRadius="16"
                Background="{StaticResource SurfaceColor}"
                Classes="Card">
            <DockPanel Margin="16">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,14">
                    <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Document}" IconVariant="Regular" FontSize="18" Foreground="{StaticResource PrimaryColor}" />
                    <TextBlock Text="模板管理" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,14">
                    <Button Content="新建模板" Command="{Binding CreateTemplateCommand}"
                            FontSize="13" Padding="12,8" />
                    <Button Content="导入" Command="{Binding ImportCommand}"
                            FontSize="13" Padding="12,8" Classes="Secondary" />
                </StackPanel>

                <ScrollViewer>
                    <ListBox ItemsSource="{Binding Templates}"
                             SelectedItem="{Binding SelectedTemplate}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Margin="0,0,0,8" Padding="14,12"
                                        Background="{StaticResource SurfaceAltColor}"
                                        Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                                <Border CornerRadius="4" Padding="4,2"
                                                        Background="{Binding Type, Converter={x:Static vm:PromptTemplateTypeColorConverter.Instance}}">
                                                    <TextBlock Text="{Binding Type}" FontSize="10" Foreground="White" />
                                                </Border>
                                                <TextBlock Text="{Binding UpdatedAt, StringFormat={}{0:MM/dd}}"
                                                           FontSize="11" Foreground="{StaticResource TextTertiary}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Button Command="{Binding $parent[ListBox].((vm:PromptTemplateViewModel)DataContext).SelectTemplateCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="8,4" Classes="Secondary">
                                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Edit}" IconVariant="Regular" FontSize="14" />
                                            </Button>
                                            <Button Command="{Binding $parent[ListBox].((vm:PromptTemplateViewModel)DataContext).DeleteTemplateCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="8,4" Classes="Danger">
                                                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Delete}" IconVariant="Regular" FontSize="14" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Margin="0,16,16,16" CornerRadius="16"
                Background="{StaticResource SurfaceColor}"
                Classes="Card">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,16">
                    <TextBlock Text="模板详情" FontSize="22" FontWeight="Bold" />
                    <Border Height="24" Width="1" Background="{StaticResource BorderColor}" />
                    <TextBlock Text="{Binding Templates.Count, StringFormat={}{0} 个模板}"
                               FontSize="14" Foreground="{StaticResource TextSecondary}" />
                </StackPanel>

                <ContentControl Content="{Binding SelectedTemplate}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:PromptTemplateViewModel">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" Height="300">
                                <Border Width="80" Height="80" CornerRadius="40" Background="{StaticResource SurfaceAltColor}">
                                    <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Info}" IconVariant="Regular" FontSize="40" Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="请选择或创建一个模板"
                                           FontSize="16"
                                           Foreground="{StaticResource TextSecondary}" />
                            </StackPanel>
                        </DataTemplate>
                        <DataTemplate DataType="models:PromptTemplate">
                            <StackPanel Spacing="20">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                                    <TextBox Grid.Row="0"
                                             Text="{Binding Name}"
                                             FontSize="20" FontWeight="Bold"
                                             PlaceholderText="模板名称" />
                                    <ComboBox Grid.Row="1"
                                              ItemsSource="{Binding $parent[ContentControl].((vm:PromptTemplateViewModel)DataContext).TemplateTypes}"
                                              SelectedItem="{Binding Type}"
                                              FontSize="14" />
                                </Grid>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="模板内容" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding Content}"
                                             AcceptsReturn="True"
                                             Height="200"
                                             PlaceholderText="输入提示词模板内容..."
                                             FontFamily="Consolas" />
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="变量说明" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding Variables}"
                                             AcceptsReturn="True"
                                             Height="100"
                                             PlaceholderText="输入变量说明，每行一个..."
                                             FontFamily="Consolas" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Content="保存修改"
                                            Command="{Binding $parent[ContentControl].((vm:PromptTemplateViewModel)DataContext).SaveTemplateCommand}"
                                            IsEnabled="{Binding $parent[ContentControl].((vm:PromptTemplateViewModel)DataContext).IsDirty}" />
                                    <Button Content="取消"
                                            Command="{Binding $parent[ContentControl].((vm:PromptTemplateViewModel)DataContext).CancelEditCommand}"
                                            Classes="Secondary" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>