<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaNovel.ViewModels"
        xmlns:ic="using:FluentIcons.Avalonia"
        xmlns:fl="using:FluentIcons.Common"
        x:Class="AvaloniaNovel.Views.CreateNovelDialogView"
        x:DataType="vm:BookshelfViewModel"
        Title="新建小说"
        Width="480"
        Height="520"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="24">
        <StackPanel Spacing="20">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ic:SymbolIcon Symbol="{x:Static fl:Symbol.Book}" IconVariant="Regular" FontSize="24"
                               Foreground="{StaticResource PrimaryColor}" />
                <TextBlock Text="新建小说" FontSize="26" FontWeight="Bold" />
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock Text="小说标题" FontWeight="SemiBold" />
                <TextBox Text="{Binding NewNovelTitle}"
                         Height="44"
                         PlaceholderText="输入小说标题" />
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock Text="题材" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding GenreOptions}"
                          SelectedItem="{Binding NewNovelGenre}"
                          Height="44" />
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock Text="世界观设定" FontWeight="SemiBold" />
                <TextBox Text="{Binding NewNovelWorldSetting}"
                         AcceptsReturn="True"
                         Height="100"
                         PlaceholderText="输入世界观设定..." />
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock Text="封面图片" FontWeight="SemiBold" />
                <Border CornerRadius="12"
                        Background="{StaticResource SurfaceAltColor}"
                        Padding="16"
                        Height="140">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Width="100" Height="108" CornerRadius="8"
                                Background="{StaticResource SurfaceColor}"
                                ClipToBounds="True">
                            <Image Source="{Binding NewNovelCoverPreview}"
                                   Stretch="UniformToFill" />
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="8">
                            <Button Content="上传封面"
                                    Command="{Binding SelectCoverCommand}"
                                    Padding="12,8" />
                            <Button Content="清除"
                                    Command="{Binding ClearCoverCommand}"
                                    IsEnabled="{Binding NewNovelCoverPreview, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Padding="12,8"
                                    Classes="Secondary" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="取消"
                        Command="{Binding CancelDialogCommand}"
                        Classes="Secondary" />
                <Button Content="创建"
                        Command="{Binding CreateNovelCommand}"
                        IsEnabled="{Binding NewNovelTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>